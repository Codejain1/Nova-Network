# -- Nova Network -- Validator Node (4GB VM) ------------------------------------
# Copy to val1.env / val2.env on each validator VM. NEVER commit .env to git.

# Chain identity -- must match main node exactly
CHAIN_NAME=Nova Network
TOKEN_NAME=Nova
TOKEN_SYMBOL=NOVA
TOKEN_DECIMALS=18
CHAIN_ID=149

# Consensus
PUBLIC_CONSENSUS=poa
PUBLIC_DIFFICULTY=3
PUBLIC_REWARD=25
PUBLIC_VALIDATOR_ROTATION=true
PUBLIC_VALIDATORS=<comma-separated validator addresses>

# -- Set this per VM --
# AUTO_MINE_MINER=<THIS_VALIDATOR_ADDRESS>
AUTO_MINE_MINER=
AUTO_MINE_INTERVAL=5

# Main node URL
MAIN_NODE_URL=https://explorer.flowpe.io

# Peer sync
PEER_SYNC_INTERVAL=6
PEER_LAG_RESYNC_THRESHOLD=1

# Mempool
PUBLIC_MEMPOOL_TTL=900
PUBLIC_MEMPOOL_MAX_SIZE=5000

# Rate limiting
RATE_LIMIT_PER_MINUTE=300

# Auth -- generate with: openssl rand -hex 32
JWT_SECRET=<GENERATE_ME>
JWT_REQUIRED=false
PEER_TOKEN=<GENERATE_ME>
