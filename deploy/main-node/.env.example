# -- Nova Network -- Main Node -------------------------------------------------
# Copy to .env and fill in real values. NEVER commit .env to git.

# Chain identity
CHAIN_NAME=Nova Network
TOKEN_NAME=Nova
TOKEN_SYMBOL=NOVA
TOKEN_DECIMALS=18
CHAIN_ID=149

# Consensus -- PoA with external validators
PUBLIC_CONSENSUS=poa
PUBLIC_DIFFICULTY=3
PUBLIC_REWARD=25
PUBLIC_VALIDATOR_ROTATION=true
PUBLIC_VALIDATORS=<comma-separated validator addresses>

# Faucet
PUBLIC_FAUCET_ENABLED=false
PUBLIC_FAUCET_AMOUNT=10
PUBLIC_FAUCET_COOLDOWN=3600
PUBLIC_FAUCET_DAILY_CAP=1000

# Mempool
PUBLIC_MEMPOOL_TTL=900
PUBLIC_MEMPOOL_MAX_SIZE=5000

# Peer sync
PEER_SYNC_INTERVAL=6
PEER_LAG_RESYNC_THRESHOLD=3

# Rate limiting
RATE_LIMIT_PER_MINUTE=300

# Auth -- generate with: openssl rand -hex 32
JWT_SECRET=<GENERATE_ME>
JWT_REQUIRED=false
PEER_TOKEN=<GENERATE_ME>
RPC_AUTH_TOKEN=<GENERATE_ME>

# EVM gateway
CORS_ORIGIN=https://explorer.flowpe.io
